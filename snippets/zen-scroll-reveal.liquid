{% comment %}
  Zen Scroll Reveal — Global entrance animation system
  Aggiunge classe .zen-revealed alle sezioni custom quando entrano nel viewport.
  Da includere una sola volta in layout/theme.liquid.

  Comportamento:
  - Threshold 0.12 per sezioni grandi (chakra, completa-rituale)
  - Threshold 0.2 per sezioni normali
  - Delay opzionale via data-reveal-delay="200"
  - Respect prefers-reduced-motion
{% endcomment %}

<style>
/* ═══════════════════════════════════════════
   ZEN SCROLL REVEAL — Global System
   ═══════════════════════════════════════════ */

/* Stato iniziale: nascosto */
[data-zen-reveal] {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94),
              transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

/* Stato rivelato */
[data-zen-reveal].zen-revealed {
  opacity: 1;
  transform: translateY(0);
}

/* Variante fade-only (senza translateY) */
[data-zen-reveal="fade"] {
  transform: none;
}

/* Variante slide-up più marcata */
[data-zen-reveal="slide-up"] {
  transform: translateY(40px);
}

/* Reduced motion: tutto visibile subito */
@media (prefers-reduced-motion: reduce) {
  [data-zen-reveal] {
    opacity: 1 !important;
    transform: none !important;
    transition: none !important;
  }
}
</style>

<script>
(function() {
  'use strict';

  if (window.__zenRevealInit) return;
  window.__zenRevealInit = true;

  /* Rispetta reduced motion */
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.querySelectorAll('[data-zen-reveal]').forEach(function(el) {
      el.classList.add('zen-revealed');
    });
    return;
  }

  function initReveal() {
    var elements = document.querySelectorAll('[data-zen-reveal]:not(.zen-revealed)');
    if (!elements.length) return;

    if (!('IntersectionObserver' in window)) {
      elements.forEach(function(el) { el.classList.add('zen-revealed'); });
      return;
    }

    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (!entry.isIntersecting) return;

        var el = entry.target;
        var delay = parseInt(el.getAttribute('data-reveal-delay')) || 0;

        if (delay > 0) {
          setTimeout(function() { el.classList.add('zen-revealed'); }, delay);
        } else {
          el.classList.add('zen-revealed');
        }

        observer.unobserve(el);
      });
    }, {
      threshold: 0.12,
      rootMargin: '0px 0px -40px 0px'
    });

    elements.forEach(function(el) { observer.observe(el); });
  }

  /* Init on DOMContentLoaded e anche su Shopify section render */
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initReveal);
  } else {
    initReveal();
  }

  /* Re-init se Shopify rende nuove sezioni (Theme Editor) */
  document.addEventListener('shopify:section:load', initReveal);
})();
</script>
