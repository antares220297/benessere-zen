{%- liquid
  assign size = size | default: 40
  assign chakra_id = chakra_id | default: 1
-%}
<svg width="{{ size }}" height="{{ size }}" viewBox="0 0 64 64" fill="none" aria-hidden="true" class="bz-glyph bz-glyph--{{ chakra_id }}">
  <circle cx="32" cy="32" r="30" stroke="currentColor" stroke-width="0.5" stroke-dasharray="1 3" opacity="0.7"/>
  <circle cx="32" cy="32" r="24" stroke="currentColor" stroke-width="0.5" opacity="0.3"/>
  {%- case chakra_id -%}
    {%- when 1 -%}
      <g stroke="currentColor" stroke-width="1">
        <path d="M 16 22 L 32 44 L 48 22 Z"/>
        <line x1="12" y1="48" x2="52" y2="48" stroke-dasharray="2 3"/>
      </g>
    {%- when 2 -%}
      <g stroke="currentColor" stroke-width="1">
        <path d="M 20 20 Q 32 28 44 20"/>
        <circle cx="32" cy="38" r="6"/>
      </g>
    {%- when 3 -%}
      <g stroke="currentColor" stroke-width="1">
        <path d="M 32 16 L 48 42 L 16 42 Z"/>
        <line x1="32" y1="46" x2="32" y2="52"/>
      </g>
    {%- when 4 -%}
      <g stroke="currentColor" stroke-width="1">
        <path d="M 20 22 L 44 22 L 32 44 Z"/>
        <path d="M 20 42 L 44 42 L 32 20 Z"/>
      </g>
    {%- when 5 -%}
      <g stroke="currentColor" stroke-width="1">
        <circle cx="32" cy="32" r="10"/>
        <line x1="32" y1="16" x2="32" y2="22"/>
        <line x1="32" y1="42" x2="32" y2="48"/>
      </g>
    {%- when 6 -%}
      <g stroke="currentColor" stroke-width="1">
        <path d="M 16 32 Q 32 18 48 32 Q 32 46 16 32 Z"/>
        <circle cx="32" cy="32" r="2.5" fill="currentColor"/>
      </g>
    {%- when 7 -%}
      <g stroke="currentColor" stroke-width="1">
        <circle cx="32" cy="32" r="4"/>
        <line x1="40" y1="32" x2="50" y2="32"/>
        <line x1="37.66" y1="37.66" x2="44.73" y2="44.73"/>
        <line x1="32" y1="40" x2="32" y2="50"/>
        <line x1="26.34" y1="37.66" x2="19.27" y2="44.73"/>
        <line x1="24" y1="32" x2="14" y2="32"/>
        <line x1="26.34" y1="26.34" x2="19.27" y2="19.27"/>
        <line x1="32" y1="24" x2="32" y2="14"/>
        <line x1="37.66" y1="26.34" x2="44.73" y2="19.27"/>
      </g>
  {%- endcase -%}
</svg>
