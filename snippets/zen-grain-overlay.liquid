{%- comment -%}
  Zen Grain Overlay — Effetto texture cinematografica globale
  Include questo snippet nel theme.liquid per applicarlo a tutto il sito.
  Opacità molto bassa (3%) per un effetto sottile ma percepibile.
{%- endcomment -%}

<div class="zen-grain-overlay" aria-hidden="true">
  <svg width="100%" height="100%">
    <filter id="zen-grain-filter">
      <feTurbulence type="fractalNoise" baseFrequency="0.75" numOctaves="4" stitchTiles="stitch" />
    </filter>
    <rect width="100%" height="100%" filter="url(#zen-grain-filter)" />
  </svg>
</div>

<style>
.zen-grain-overlay {
  position: fixed;
  inset: 0;
  width: 100%;
  height: 100%;
  pointer-events: none;
  z-index: 9998;
  opacity: 0.028;
}

.zen-grain-overlay svg {
  width: 100%;
  height: 100%;
}

/* Disabilita su mobile per performance */
@media (max-width: 768px) {
  .zen-grain-overlay {
    display: none;
  }
}

/* Rispetta reduced motion */
@media (prefers-reduced-motion: reduce) {
  .zen-grain-overlay {
    display: none;
  }
}
</style>
