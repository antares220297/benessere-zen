{%- comment -%}
  Zen Scroll Progress Bar — Barra di avanzamento dello scroll
  Barra sottile in cima al viewport che mostra il progresso dello scroll.
{%- endcomment -%}

<div class="zen-scroll-progress" aria-hidden="true">
  <div class="zen-scroll-progress__bar"></div>
</div>

<style>
.zen-scroll-progress {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  height: 3px;
  background: rgba(15, 15, 15, 0.3);
  z-index: 9999;
  pointer-events: none;
}

.zen-scroll-progress__bar {
  height: 100%;
  width: 0%;
  background: linear-gradient(90deg, #C9A84C, #E8D48E);
  transition: width 0.05s linear;
  will-change: width;
}
</style>

<script>
(function() {
  var bar = document.querySelector('.zen-scroll-progress__bar');
  if (!bar) return;

  var ticking = false;

  function updateProgress() {
    var scrollTop = window.pageYOffset || document.documentElement.scrollTop;
    var docHeight = document.documentElement.scrollHeight - window.innerHeight;
    var progress = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    bar.style.width = progress + '%';
  }

  window.addEventListener('scroll', function() {
    if (!ticking) {
      requestAnimationFrame(function() {
        updateProgress();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });

  updateProgress();
})();
</script>
