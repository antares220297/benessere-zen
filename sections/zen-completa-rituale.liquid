      "limit": 4,
      "settings": [
        { "type": "text", "id": "bundle_name", "label": "Nome bundle", "default": "Rituale del Radicamento" },
        { "type": "text", "id": "chakra_name", "label": "Nome chakra", "default": "Muladhara" },
        { "type": "color", "id": "color", "label": "Colore accento", "default": "#E63946" },
        { "type": "text", "id": "item_1", "label": "Item 1", "default": "Diaspro Rosso" },
        { "type": "text", "id": "item_2", "label": "Item 2", "default": "Incenso Patchouli" },
        { "type": "text", "id": "item_3", "label": "Item 3", "default": "Tè Muladhara" },
        { "type": "text", "id": "item_4", "label": "Item 4", "default": "Portaincenso in legno" },
        { "type": "text", "id": "price", "label": "Prezzo bundle", "default": "€38,90" },
        { "type": "text", "id": "compare_price", "label": "Prezzo barrato", "default": "€47,60" },
        { "type": "text", "id": "savings", "label": "Messaggio risparmio", "default": "Risparmi il 18%" },
        { "type": "text", "id": "cta_text", "label": "Testo CTA", "default": "Aggiungi al Carrello" },
        { "type": "url", "id": "cta_link", "label": "Link CTA" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zen Completa il Rituale",
      "blocks": [
