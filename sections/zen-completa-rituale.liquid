        { "type": "bundle", "settings": { "bundle_name": "Rituale della Serenità", "chakra_name": "Anahata", "color": "#06D6A0", "item_1": "Quarzo Rosa", "item_2": "Salvia Bianca", "item_3": "Tè Anahata", "item_4": "Candela alla soia", "price": "€36,90", "compare_price": "€44,80", "savings": "Risparmi il 18%" } }
      ]
    }
  ]
}
{% endschema %}