{% comment %}
  Zen Completa il Tuo Rituale — Bundle cross-sell section
  3 bundle tematici con tab selector, 4 item ciascuno, prezzo scontato.
{% endcomment %}

<section class="zen-completa" data-section-id="{{ section.id }}" data-zen-reveal>
  <div class="zen-completa__container">

    <!-- Header -->
    <header class="zen-completa__header">
      <span class="zen-completa__eyebrow">{{ section.settings.eyebrow | default: 'Bundle Esclusivi' }}</span>
      <h2 class="zen-completa__title">
        {{ section.settings.heading | default: 'Completa il Tuo' }}
        <em>{{ section.settings.heading_accent | default: 'Rituale' }}</em>
      </h2>
      <p class="zen-completa__subtitle">{{ section.settings.subtitle | default: 'Ogni bundle è un&rsquo;esperienza completa — cristallo, incenso, tè e accessorio, scelti per lavorare in sinergia.' }}</p>
      <div class="zen-completa__divider" aria-hidden="true"></div>
    </header>

    <!-- Bundle tabs -->
    <div class="zen-completa__tabs" role="tablist">
      {% for block in section.blocks %}
        {% if block.type == 'bundle' %}
          <button class="zen-completa__tab {% if forloop.first %}is-active{% endif %}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-controls="bundle-{{ block.id }}"
                  data-bundle-index="{{ forloop.index0 }}"
                  style="--bundle-color: {{ block.settings.color | default: '#C9A84C' }};"
                  {{ block.shopify_attributes }}>
            {{ block.settings.bundle_name }}
          </button>
        {% endif %}
      {% endfor %}
    </div>

    <!-- Bundle panels -->
    {% for block in section.blocks %}
      {% if block.type == 'bundle' %}
        <div class="zen-completa__panel {% if forloop.first %}is-active{% endif %}"
             id="bundle-{{ block.id }}"
             role="tabpanel"
             data-bundle-index="{{ forloop.index0 }}"
             style="--bundle-color: {{ block.settings.color | default: '#C9A84C' }};">

          <div class="zen-completa__panel-inner">
            <!-- Items grid -->
            <div class="zen-completa__items">
              {% assign items = block.settings.item_1 | append: '|' | append: block.settings.item_2 | append: '|' | append: block.settings.item_3 | append: '|' | append: block.settings.item_4 %}
              {% assign item_names = items | split: '|' %}
              {% for item in item_names %}
                {% if item != blank %}
                  <div class="zen-completa__item">
                    <div class="zen-completa__item-icon" aria-hidden="true">◆</div>
                    <span class="zen-completa__item-name">{{ item }}</span>
                  </div>
                {% endif %}
              {% endfor %}
            </div>

            <!-- Pricing & CTA -->
            <div class="zen-completa__pricing">
              <span class="zen-completa__chakra-label" style="color: {{ block.settings.color }};">
                Chakra {{ block.settings.chakra_name | default: 'Chakra' }}
              </span>
              <div class="zen-completa__price">{{ block.settings.price | default: '€38,90' }}</div>
              {% if block.settings.compare_price != blank %}
                <div class="zen-completa__compare">{{ block.settings.compare_price }}</div>
              {% endif %}
              {% if block.settings.savings != blank %}
                <div class="zen-completa__savings" style="color: {{ block.settings.color }};">{{ block.settings.savings }}</div>
              {% endif %}
              <a href="{{ block.settings.cta_link | default: '/cart' }}"
                  class="zen-completa__cta"
                 style="background: {{ block.settings.color | default: '#C9A84C' }};">
                {{ block.settings.cta_text | default: 'Aggiungi al Carrello' }}
              </a>
            </div>
          </div>
        </div>
      {% endif %}
    {% endfor %}
  </div>
</section>

<style>
/* ═══════════════════════════════════════════
   ZEN COMPLETA IL TUO RITUALE — Bundles
   ═══════════════════════════════════════════ */
.zen-completa {
  background: linear-gradient(180deg, #0D0D14, #0F0F0F);
  padding: 80px 20px;
  position: relative;
}

.zen-completa__container {
  max-width: 1000px;
  margin: 0 auto;
}

/* Header */
.zen-completa__header {
  text-align: center;
  margin-bottom: 40px;
}

.zen-completa__eyebrow {
  display: block;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #C9A84C;
  margin-bottom: 16px;
  font-weight: 600;
}

.zen-completa__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 300;
  color: #E8E8E8;
  margin: 0 0 14px;
  line-height: 1.25;
}

.zen-completa__title em {
  color: #C9A84C;
  font-style: italic;
}

.zen-completa__subtitle {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 15px;
  color: rgba(232, 232, 232, 0.6);
  max-width: 600px;
  margin: 0 auto 22px;
  line-height: 1.6;
}

.zen-completa__divider {
  width: 50px;
  height: 2px;
  margin: 0 auto;
  background: linear-gradient(90deg, transparent, #C9A84C, transparent);
}

/* Tabs */
.zen-completa__tabs {
  display: flex;
  gap: 10px;
  justify-content: center;
  margin-bottom: 40px;
  flex-wrap: wrap;
}

.zen-completa__tab {
  padding: 10px 22px;
  border-radius: 999px;
  background: transparent;
  border: 1px solid rgba(201, 168, 76, 0.15);
  color: rgba(232, 232, 232, 0.6);
  font-family: 'Josefin Sans', sans-serif;
  font-size: 12px;
  font-weight: 600;
  letter-spacing: 1px;
  cursor: pointer;
  transition: all 0.3s ease;
}

.zen-completa__tab.is-active {
  background: color-mix(in srgb, var(--bundle-color) 14%, transparent);
  border-color: color-mix(in srgb, var(--bundle-color) 45%, transparent);
  color: var(--bundle-color);
}

.zen-completa__tab:hover:not(.is-active) {
  border-color: rgba(201, 168, 76, 0.3);
  color: #E8E8E8;
}

/* Panels */
.zen-completa__panel {
  display: none;
}

.zen-completa__panel.is-active {
  display: block;
}

.zen-completa__panel-inner {
  display: flex;
  gap: 32px;
  align-items: center;
  padding: 40px;
  background: #111118;
  border: 1px solid color-mix(in srgb, var(--bundle-color) 18%, transparent);
  border-radius: 24px;
  transition: border-color 0.5s ease;
}

/* Items grid */
.zen-completa__items {
  flex: 1;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 14px;
}

.zen-completa__item {
  padding: 20px;
  border-radius: 16px;
  background: color-mix(in srgb, var(--bundle-color) 5%, transparent);
  border: 1px solid color-mix(in srgb, var(--bundle-color) 10%, transparent);
  text-align: center;
}

.zen-completa__item-icon {
  font-size: 24px;
  color: color-mix(in srgb, var(--bundle-color) 30%, transparent);
  margin-bottom: 8px;
}

.zen-completa__item-name {
  font-size: 13px;
  color: #E8E8E8;
  font-weight: 500;
}

/* Pricing */
.zen-completa__pricing {
  min-width: 220px;
  text-align: center;
}

.zen-completa__chakra-label {
  display: block;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
  margin-bottom: 12px;
}

.zen-completa__price {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 38px;
  font-weight: 300;
  color: #E8E8E8;
  margin-bottom: 4px;
}

.zen-completa__compare {
  font-size: 14px;
  color: rgba(232, 232, 232, 0.4);
  text-decoration: line-through;
  margin-bottom: 6px;
}

.zen-completa__savings {
  font-size: 12px;
  font-weight: 600;
  margin-bottom: 24px;
}

.zen-completa__cta {
  display: block;
  width: 100%;
  padding: 15px 36px;
  color: #fff;
  border: none;
  border-radius: 4px;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 13px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-align: center;
  text-decoration: none;
  transition: filter 0.3s ease;
  box-shadow: 0 6px 30px color-mix(in srgb, var(--bundle-color) 25%, transparent);
}

.zen-completa__cta:hover {
  filter: brightness(1.1);
  color: #fff;
}

/* Responsive */
@media (max-width: 768px) {
  .zen-completa__panel-inner {
    flex-direction: column;
    padding: 28px 20px;
  }

  .zen-completa__items {
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  .zen-completa__pricing {
    width: 100%;
    min-width: auto;
    margin-top: 8px;
  }

  .zen-completa { padding: 60px 16px; }
}

@media (prefers-reduced-motion: reduce) {
  .zen-completa__panel-inner,
  .zen-completa__tab {
    transition: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var section = document.querySelector('.zen-completa');
  if (!section) return;

  var tabs = section.querySelectorAll('.zen-completa__tab');
  var panels = section.querySelectorAll('.zen-completa__panel');

  tabs.forEach(function(tab) {
    tab.addEventListener('click', function() {
      var index = this.getAttribute('data-bundle-index');

      /* Reset all */
      tabs.forEach(function(t) {
        t.classList.remove('is-active');
        t.setAttribute('aria-selected', 'false');
      });
      panels.forEach(function(p) { p.classList.remove('is-active'); });

      /* Activate selected */
      this.classList.add('is-active');
      this.setAttribute('aria-selected', 'true');

      var target = section.querySelector('.zen-completa__panel[data-bundle-index="' + index + '"]');
      if (target) target.classList.add('is-active');
    });
  });

  /* Keyboard navigation */
  tabs.forEach(function(tab, i) {
    tab.addEventListener('keydown', function(e) {
      var newIndex;
      if (e.key === 'ArrowRight') {
        newIndex = (i + 1) % tabs.length;
      } else if (e.key === 'ArrowLeft') {
        newIndex = (i - 1 + tabs.length) % tabs.length;
      } else {
        return;
      }
      e.preventDefault();
      tabs[newIndex].click();
      tabs[newIndex].focus();
    });
  });
});
</script>

{% schema %}
{
  "name": "Zen Completa il Rituale",
  "class": "zen-completa-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Bundle Esclusivi" },
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Completa il Tuo" },
    { "type": "text", "id": "heading_accent", "label": "Titolo accento (in oro)", "default": "Rituale" },
    { "type": "textarea", "id": "subtitle", "label": "Sottotitolo", "default": "Ogni bundle è un'esperienza completa — cristallo, incenso, tè e accessorio, scelti per lavorare in sinergia." }
  ],
  "blocks": [
    {
      "type": "bundle",
