{%- comment -%}
  BenesserEZen — Featured Collections (3-up editorial card grid).

  Each block represents one collection, paired to a chakra (1-7) which
  controls accent colour and the SVG glyph used as backdrop.

  At 1 block the grid collapses to a single column; at 2 it's 2-up;
  3+ stays at 3 columns, wrapping to a second row from 4 onwards.
{%- endcomment -%}

<section
  class="bz-collections color-{{ section.settings.color_scheme }} gradient isolate"
  data-section-id="{{ section.id }}"
>
  <div class="page-width bz-collections__inner">
    <header class="bz-collections__header">
      <p class="bz-label bz-reveal">{{ section.settings.eyebrow | default: 'Collezioni in evidenza' }}</p>
      <h2 class="bz-title bz-reveal" data-delay="1">{{ section.settings.heading | default: 'I rituali più amati' }}</h2>
      {%- if section.settings.subtext != blank -%}
        <p class="bz-body bz-reveal" data-delay="2">{{ section.settings.subtext }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div
        class="bz-collections__grid"
        data-count="{{ section.blocks.size }}"
      >
        {%- for block in section.blocks -%}
          {%- liquid
            assign chakra = block.settings.chakra_id | default: 1
            assign coll = block.settings.collection
            assign card_title = block.settings.title_override
            if card_title == blank and coll != blank
              assign card_title = coll.title
            endif
            if card_title == blank
              assign card_title = 'Collezione'
            endif
            assign card_href = '#'
            if coll != blank
              assign card_href = coll.url
            endif
          -%}
          <a
            class="bz-col-card bz-reveal"
            data-delay="{{ forloop.index0 | plus: 1 | at_most: 5 }}"
            href="{{ card_href }}"
            style="--chakra-c: var(--chakra-{{ chakra }}); --chakra-c-rgb: var(--chakra-{{ chakra }}-rgb);"
            {{ block.shopify_attributes }}
          >
            <div class="bz-col-card__bg" aria-hidden="true">
              {%- render 'bz-chakra-glyph', chakra_id: chakra, size: 240 -%}
            </div>
            <div class="bz-col-card__overlay" aria-hidden="true"></div>
            <div class="bz-col-card__content">
              <span class="bz-col-card__dot" aria-hidden="true"></span>
              <h3 class="bz-col-card__title">{{ card_title | escape }}</h3>
              {%- if block.settings.subtitle != blank -%}
                <p class="bz-col-card__sub">{{ block.settings.subtitle }}</p>
              {%- endif -%}
              <span class="bz-col-card__cta">
                {{ block.settings.cta_label | default: 'Scopri' }}
                <span class="bz-col-card__arrow" aria-hidden="true">→</span>
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  .bz-collections {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .bz-collections__inner {
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }
  .bz-collections__header {
    text-align: center;
    max-width: 60rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }
  .bz-collections__header .bz-label,
  .bz-collections__header .bz-title { margin: 0; }

  .bz-collections__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.5px;
    background: var(--bz-border);
    padding: 1.5px;
  }
  .bz-collections__grid[data-count="1"] { grid-template-columns: 1fr; }
  .bz-collections__grid[data-count="2"] { grid-template-columns: repeat(2, minmax(0, 1fr)); }

  /* === Card === */
  .bz-col-card {
    position: relative;
    display: block;
    aspect-ratio: 3 / 4;
    overflow: hidden;
    text-decoration: none;
    background: var(--bz-bg-2);
    transition: transform var(--bz-duration) var(--bz-ease);
  }
  .bz-col-card:hover { transform: translateY(-2px); }

  .bz-col-card__bg {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--chakra-c, var(--bz-gold));
    opacity: 0.18;
    transition: transform 0.7s var(--bz-ease),
                opacity var(--bz-duration) var(--bz-ease);
    will-change: transform;
  }
  .bz-col-card:hover .bz-col-card__bg {
    transform: scale(1.06);
    opacity: 0.26;
  }

  .bz-col-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top,
      rgba(0, 0, 0, 0.92) 0%,
      rgba(0, 0, 0, 0.55) 35%,
      transparent 65%);
    pointer-events: none;
  }

  .bz-col-card__content {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 2.4rem 2rem 2.4rem;
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
    color: var(--bz-text);
  }
  .bz-col-card__dot {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 50%;
    background: var(--chakra-c, var(--bz-gold));
    box-shadow: 0 0 12px rgba(var(--chakra-c-rgb, 201, 168, 76), 0.6);
  }
  .bz-col-card__title {
    margin: 0;
    font-family: var(--bz-font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(2rem, 2.4vw, 2.8rem);
    line-height: 1.1;
    color: var(--bz-text);
  }
  .bz-col-card__sub {
    margin: 0;
    font-family: var(--bz-font-ui);
    font-size: 1rem;
    letter-spacing: 0.25rem;
    text-transform: uppercase;
    color: var(--bz-muted);
  }
  .bz-col-card__cta {
    margin-top: 0.8rem;
    font-family: var(--bz-font-ui);
    font-size: 1.1rem;
    font-weight: 400;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    color: var(--bz-gold);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity var(--bz-duration) var(--bz-ease),
                transform var(--bz-duration) var(--bz-ease);
  }
  .bz-col-card__arrow {
    display: inline-block;
    transition: transform var(--bz-duration) var(--bz-ease);
  }
  .bz-col-card:hover .bz-col-card__cta,
  .bz-col-card:focus-visible .bz-col-card__cta {
    opacity: 1;
    transform: translateY(0);
  }
  .bz-col-card:hover .bz-col-card__arrow,
  .bz-col-card:focus-visible .bz-col-card__arrow {
    transform: translateX(4px);
  }
  .bz-col-card:focus-visible {
    outline: 2px solid var(--bz-gold);
    outline-offset: -3px;
  }

  /* === Responsive === */
  @media (max-width: 989px) {
    .bz-collections__grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .bz-collections__grid[data-count="1"] { grid-template-columns: 1fr; }
  }
  @media (max-width: 749px) {
    .bz-collections__grid,
    .bz-collections__grid[data-count="1"],
    .bz-collections__grid[data-count="2"] {
      grid-template-columns: 1fr;
    }
    .bz-col-card__cta { opacity: 1; transform: none; }
  }
{% endstyle %}

{% schema %}
{
  "name": "BZ Featured Collections",
  "class": "bz-collections-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "Schema colore"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etichetta",
      "default": "Collezioni in evidenza"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titolo",
      "default": "I rituali più amati"
    },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Sottotesto"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding alto",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding basso",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collezione",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collezione"
        },
        {
          "type": "range",
          "id": "chakra_id",
          "min": 1,
          "max": 7,
          "step": 1,
          "label": "Chakra (colore + glifo)",
          "default": 1
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Titolo (sovrascrive il nome della collection)"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Sottotitolo",
          "info": "Es: «Muladhara · Radicamento»"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Testo CTA",
          "default": "Scopri"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BZ Featured Collections",
      "blocks": [
        {
          "type": "collection",
          "settings": {
            "chakra_id": 1,
            "title_override": "Cristalli Radice",
            "subtitle": "Mūlādhāra · Radicamento"
          }
        },
        {
          "type": "collection",
          "settings": {
            "chakra_id": 4,
            "title_override": "Cristalli Cuore",
            "subtitle": "Anāhata · Compassione"
          }
        },
        {
          "type": "collection",
          "settings": {
            "chakra_id": 7,
            "title_override": "Cristalli Corona",
            "subtitle": "Sahasrāra · Coscienza"
          }
        }
      ]
    }
  ]
}
{% endschema %}
