{% comment %}
  Zen Rituale del Momento — Sezione stagionale/lunare
  Mostra un rituale curato in base alla stagione corrente.
  Il contenuto cambia automaticamente basandosi sul mese.
{% endcomment %}

{%- assign current_month = 'now' | date: '%m' | plus: 0 -%}
{%- if current_month >= 3 and current_month <= 5 -%}
  {%- assign season = 'primavera' -%}
  {%- assign season_title = 'Equinozio di Primavera' -%}
  {%- assign season_subtitle = 'Rituali di Rinascita' -%}
  {%- assign season_text = "L'energia della primavera risveglia il chakra del cuore. È il momento perfetto per lasciar andare il vecchio e accogliere nuove intenzioni con un rituale di purificazione." -%}
  {%- assign season_icon = '❋' -%}
  {%- assign season_color = '#06D6A0' -%}
  {%- assign moon_label = 'Tempo di Rinnovamento' -%}
{%- elsif current_month >= 6 and current_month <= 8 -%}
  {%- assign season = 'estate' -%}
  {%- assign season_title = 'Solstizio d&rsquo;Estate' -%}
  {%- assign season_subtitle = 'Rituali di Espansione' -%}
  {%- assign season_text = "L'energia solare è al suo apice. Il plesso solare brilla: è il momento di manifestare, agire e irradiare la tua luce interiore con forza." -%}
  {%- assign season_icon = '☉' -%}
  {%- assign season_color = '#FFBE0B' -%}
  {%- assign moon_label = 'Tempo di Espansione' -%}
{%- elsif current_month >= 9 and current_month <= 11 -%}
  {%- assign season = 'autunno' -%}
  {%- assign season_title = 'Equinozio d&rsquo;Autunno' -%}
  {%- assign season_subtitle = 'Rituali di Introspezione' -%}
  {%- assign season_text = "Le foglie cadono, l'energia si ritira verso l'interno. È il momento di meditare, purificare gli spazi e coltivare la gratitudine per il raccolto dell'anima." -%}
  {%- assign season_icon = '☽' -%}
  {%- assign season_color = '#FF8C42' -%}
  {%- assign moon_label = 'Tempo di Introspezione' -%}
{%- else -%}
  {%- assign season = 'inverno' -%}
  {%- assign season_title = 'Solstizio d&rsquo;Inverno' -%}
  {%- assign season_subtitle = 'Rituali di Quiete' -%}
  {%- assign season_text = "Il mondo riposa sotto la neve. Il chakra della corona si apre al silenzio. È il momento per la meditazione profonda, il tè caldo e la contemplazione." -%}
  {%- assign season_icon = '✧' -%}
  {%- assign season_color = '#6A4C93' -%}
  {%- assign moon_label = 'Tempo di Quiete' -%}
{%- endif -%}

<section class="zen-rituale-momento" data-section-id="{{ section.id }}" data-season="{{ season }}">
  <div class="zen-rituale-momento__container">

    <!-- Colonna visuale: Moon phase card -->
    <div class="zen-rituale-momento__visual">
      <div class="zen-rituale-momento__moon-card">
        <!-- Decorative moon phase -->
        <div class="zen-rituale-momento__moon" aria-hidden="true">
          <div class="zen-rituale-momento__moon-glow" style="background: radial-gradient(circle at 60% 40%, {{ season_color }}44, {{ season_color }}11);"></div>
          <div class="zen-rituale-momento__moon-shadow"></div>
        </div>
        <!-- Season info -->
        <div class="zen-rituale-momento__moon-info">
          <span class="zen-rituale-momento__moon-label">{{ season_icon }} {{ moon_label }}</span>
          <h3 class="zen-rituale-momento__moon-title">{{ season_title }}</h3>
          <span class="zen-rituale-momento__moon-date">{{ season_subtitle }}</span>
        </div>
      </div>
    </div>

    <!-- Colonna contenuto -->
    <div class="zen-rituale-momento__content">
      <span class="zen-rituale-momento__eyebrow">
        {{ section.settings.eyebrow | default: 'Il Rituale del Momento' }}
      </span>
      <h2 class="zen-rituale-momento__heading">
        {{ section.settings.heading | default: 'Tempo di' }}
        <em>{{ section.settings.heading_accent | default: moon_label | remove: 'Tempo di ' }}</em>
      </h2>
      <p class="zen-rituale-momento__text">
        {{ section.settings.text | default: season_text }}
      </p>

      <!-- Bundle items tags -->
      {% if section.blocks.size > 0 %}
        <div class="zen-rituale-momento__bundle-tags">
          {% for block in section.blocks %}
            <span class="zen-rituale-momento__tag" {{ block.shopify_attributes }}>
              {{ block.settings.item_name }}
            </span>
          {% endfor %}
        </div>
      {% else %}
        <div class="zen-rituale-momento__bundle-tags">
          <span class="zen-rituale-momento__tag">Salvia Bianca</span>
          <span class="zen-rituale-momento__tag">Quarzo Rosa</span>
          <span class="zen-rituale-momento__tag">Tè Anahata</span>
        </div>
      {% endif %}

      <!-- CTA -->
      <div class="zen-rituale-momento__cta-row">
        <a href="{{ section.settings.cta_link | default: '/collections/all' }}" class="zen-rituale-momento__btn">
          {{ section.settings.cta_text | default: 'Scopri il Bundle Stagionale' }}
        </a>
        {% if section.settings.price != blank %}
          <span class="zen-rituale-momento__price">{{ section.settings.price }}</span>
          {% if section.settings.compare_price != blank %}
            <span class="zen-rituale-momento__compare-price">{{ section.settings.compare_price }}</span>
          {% endif %}
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
/* ═══════════════════════════════════════════
   ZEN RITUALE DEL MOMENTO — Seasonal Section
   ═══════════════════════════════════════════ */
.zen-rituale-momento {
  background: linear-gradient(135deg, #0F0F0F, #0E0E18);
  padding: 80px 20px;
  position: relative;
  overflow: hidden;
}

.zen-rituale-momento__container {
  max-width: 1100px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 50px;
}

/* --- Visual column: Moon card --- */
.zen-rituale-momento__visual {
  flex-shrink: 0;
  width: 320px;
}

.zen-rituale-momento__moon-card {
  position: relative;
  height: 380px;
  border-radius: 24px;
  background: linear-gradient(160deg, #1A1A2E, #0D0D14);
  border: 1px solid rgba(201, 168, 76, 0.12);
  overflow: hidden;
}

.zen-rituale-momento__moon {
  position: absolute;
  top: 15%;
  left: 50%;
  transform: translateX(-50%);
  width: 100px;
  height: 100px;
}

.zen-rituale-momento__moon-glow {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-shadow: 0 0 60px rgba(201, 168, 76, 0.15);
  position: relative;
}

.zen-rituale-momento__moon-shadow {
  position: absolute;
  top: -5px;
  right: -5px;
  width: 80px;
  height: 110px;
  border-radius: 50%;
  background: #0D0D14;
}

.zen-rituale-momento__moon-info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 28px;
  background: linear-gradient(to top, #0F0F0FEE, transparent);
}

.zen-rituale-momento__moon-label {
  display: block;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: #C9A84C;
  margin-bottom: 8px;
}

.zen-rituale-momento__moon-title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 22px;
  font-weight: 300;
  color: #E8E8E8;
  margin: 0 0 4px;
  line-height: 1.3;
}

.zen-rituale-momento__moon-date {
  font-size: 12px;
  color: rgba(232, 232, 232, 0.5);
}

/* --- Content column --- */
.zen-rituale-momento__eyebrow {
  display: block;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #C9A84C;
  margin-bottom: 14px;
  font-weight: 600;
}

.zen-rituale-momento__heading {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(28px, 3.5vw, 42px);
  font-weight: 300;
  color: #E8E8E8;
  margin: 0 0 16px;
  line-height: 1.3;
}

.zen-rituale-momento__heading em {
  color: #C9A84C;
  font-style: italic;
}

.zen-rituale-momento__text {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 15px;
  color: rgba(232, 232, 232, 0.7);
  line-height: 1.7;
  margin-bottom: 24px;
  max-width: 500px;
}

/* Bundle tags */
.zen-rituale-momento__bundle-tags {
  display: flex;
  gap: 10px;
  margin-bottom: 24px;
  flex-wrap: wrap;
}

.zen-rituale-momento__tag {
  padding: 8px 16px;
  background: rgba(201, 168, 76, 0.06);
  border: 1px solid rgba(201, 168, 76, 0.15);
  border-radius: 20px;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 12px;
  color: #E8E8E8;
}

/* CTA */
.zen-rituale-momento__cta-row {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}

.zen-rituale-momento__btn {
  display: inline-block;
  padding: 14px 32px;
  background: #C9A84C;
  color: #0F0F0F;
  border: none;
  border-radius: 2px;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 12px;
  font-weight: 700;
  letter-spacing: 2px;
  text-transform: uppercase;
  text-decoration: none;
  transition: background 0.3s ease;
}

.zen-rituale-momento__btn:hover {
  background: #B8933B;
  color: #0F0F0F;
}

.zen-rituale-momento__price {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: #E8E8E8;
}

.zen-rituale-momento__compare-price {
  font-size: 13px;
  color: rgba(232, 232, 232, 0.4);
  text-decoration: line-through;
}

/* --- Responsive --- */
@media (max-width: 768px) {
  .zen-rituale-momento__container {
    flex-direction: column;
    gap: 32px;
  }

  .zen-rituale-momento__visual {
    width: 100%;
    max-width: 340px;
  }

  .zen-rituale-momento__moon-card {
    height: 300px;
  }

  .zen-rituale-momento { padding: 60px 16px; }
}

/* --- Entrance animation (Intersection Observer) --- */
.zen-rituale-momento__visual,
.zen-rituale-momento__content {
  opacity: 0;
  transform: translateY(30px);
  transition: opacity 0.8s ease, transform 0.8s ease;
}

.zen-rituale-momento__visual.is-visible,
.zen-rituale-momento__content.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.zen-rituale-momento__content.is-visible {
  transition-delay: 0.15s;
}

@media (prefers-reduced-motion: reduce) {
  .zen-rituale-momento__visual,
  .zen-rituale-momento__content {
    opacity: 1;
    transform: none;
    transition: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var section = document.querySelector('.zen-rituale-momento');
  if (!section) return;

  var targets = section.querySelectorAll('.zen-rituale-momento__visual, .zen-rituale-momento__content');

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.2 });

    targets.forEach(function(el) { observer.observe(el); });
  } else {
    targets.forEach(function(el) { el.classList.add('is-visible'); });
  }
});
</script>

{% schema %}
{
  "name": "Zen Rituale del Momento",
  "class": "zen-rituale-momento-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "Il Rituale del Momento" },
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Tempo di" },
    { "type": "text", "id": "heading_accent", "label": "Titolo accento (in oro)", "default": "", "info": "Lascia vuoto per usare il testo stagionale automatico" },
    { "type": "textarea", "id": "text", "label": "Descrizione", "default": "", "info": "Lascia vuoto per il testo stagionale automatico" },
    { "type": "text", "id": "cta_text", "label": "Testo CTA", "default": "Scopri il Bundle Stagionale" },
    { "type": "url", "id": "cta_link", "label": "Link CTA" },
    { "type": "text", "id": "price", "label": "Prezzo bundle (es: €34,90)", "default": "" },
    { "type": "text", "id": "compare_price", "label": "Prezzo barrato (es: €41,70)", "default": "" }
  ],
  "blocks": [
    {
      "type": "bundle_item",
      "name": "Prodotto nel bundle",
      "limit": 5,
      "settings": [
        { "type": "text", "id": "item_name", "label": "Nome prodotto", "default": "Prodotto" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zen Rituale del Momento",
      "blocks": [
        { "type": "bundle_item", "settings": { "item_name": "Salvia Bianca" } },
        { "type": "bundle_item", "settings": { "item_name": "Quarzo Rosa" } },
        { "type": "bundle_item", "settings": { "item_name": "Tè Anahata" } }
      ]
    }
  ]
}
{% endschema %}