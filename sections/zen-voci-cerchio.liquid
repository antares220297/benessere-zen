{% comment %}
  Zen Voci dal Cerchio — UGC / Community showcase
  Griglia di card con immagini clienti e citazioni.
  Configurabile dal Theme Customizer con blocks.
{% endcomment %}

<section class="zen-voci" data-section-id="{{ section.id }}">
  <div class="zen-voci__container">

    <!-- Header -->
    <header class="zen-voci__header">
      <span class="zen-voci__eyebrow">{{ section.settings.eyebrow | default: 'La Nostra Comunità' }}</span>
      <h2 class="zen-voci__title">
        {{ section.settings.heading | default: 'Voci dal' }}
        <em>{{ section.settings.heading_accent | default: 'Cerchio' }}</em>
      </h2>
      <div class="zen-voci__divider" aria-hidden="true"></div>
    </header>

    <!-- Grid -->
    <div class="zen-voci__grid">
      {% for block in section.blocks %}
        <div class="zen-voci__card" data-card-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <!-- Image -->
          <div class="zen-voci__card-media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.alt_text | default: 'Comunità Benessere Zen' }}"
                loading="lazy"
                class="zen-voci__card-img"
              >
            {% else %}
              <div class="zen-voci__card-placeholder">
                <span>✦</span>
              </div>
            {% endif %}
            <!-- Hover overlay -->
            <div class="zen-voci__card-overlay">
              {% if block.settings.quote != blank %}
                <p class="zen-voci__card-quote">"{{ block.settings.quote }}"</p>
              {% endif %}
              {% if block.settings.username != blank %}
                <span class="zen-voci__card-username">{{ block.settings.username }}</span>
              {% endif %}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    <!-- Instagram CTA -->
    {% if section.settings.instagram_url != blank %}
      <div class="zen-voci__cta">
        <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener" class="zen-voci__cta-link">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
          {{ section.settings.instagram_text | default: 'Seguici su Instagram' }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

<style>
/* ═══════════════════════════════════════════
   ZEN VOCI DAL CERCHIO — UGC Grid
   ═══════════════════════════════════════════ */
.zen-voci {
  background: #0F0F0F;
  padding: 80px 20px;
}

.zen-voci__container {
  max-width: 1100px;
  margin: 0 auto;
}

/* Header */
.zen-voci__header {
  text-align: center;
  margin-bottom: 48px;
}

.zen-voci__eyebrow {
  display: block;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: #C9A84C;
  margin-bottom: 16px;
  font-weight: 600;
}

.zen-voci__title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: clamp(32px, 4.5vw, 52px);
  font-weight: 300;
  color: #E8E8E8;
  margin: 0 0 22px;
  line-height: 1.25;
}

.zen-voci__title em {
  color: #C9A84C;
  font-style: italic;
}

.zen-voci__divider {
  width: 50px;
  height: 2px;
  margin: 0 auto;
  background: linear-gradient(90deg, transparent, #C9A84C, transparent);
}

/* Grid — masonry-like with fixed rows */
.zen-voci__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 12px;
}

/* Card */
.zen-voci__card {
  position: relative;
  border-radius: 8px;
  overflow: hidden;
  aspect-ratio: 1;
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.6s ease, transform 0.6s ease;
}

.zen-voci__card.is-visible {
  opacity: 1;
  transform: translateY(0);
}

.zen-voci__card-media {
  position: relative;
  width: 100%;
  height: 100%;
}

.zen-voci__card-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}

.zen-voci__card:hover .zen-voci__card-img {
  transform: scale(1.06);
}

.zen-voci__card-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #1A1A2E, #111118);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  color: rgba(201, 168, 76, 0.15);
}

/* Hover overlay */
.zen-voci__card-overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(10, 10, 15, 0.92), rgba(10, 10, 15, 0.4) 50%, transparent);
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 16px;
  opacity: 0;
  transition: opacity 0.35s ease;
}

.zen-voci__card:hover .zen-voci__card-overlay {
  opacity: 1;
}

.zen-voci__card-quote {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 14px;
  font-style: italic;
  color: #E8E8E8;
  line-height: 1.5;
  margin: 0 0 6px;
}

.zen-voci__card-username {
  font-family: 'Josefin Sans', sans-serif;
  font-size: 10px;
  letter-spacing: 1px;
  color: #C9A84C;
  text-transform: uppercase;
}

/* Instagram CTA */
.zen-voci__cta {
  text-align: center;
  margin-top: 36px;
}

.zen-voci__cta-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 28px;
  border: 1px solid rgba(201, 168, 76, 0.2);
  border-radius: 999px;
  color: #C9A84C;
  font-family: 'Josefin Sans', sans-serif;
  font-size: 12px;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  text-decoration: none;
  transition: all 0.3s ease;
}

.zen-voci__cta-link:hover {
  background: rgba(201, 168, 76, 0.08);
  border-color: rgba(201, 168, 76, 0.4);
  color: #C9A84C;
}

/* Responsive */
@media (max-width: 768px) {
  .zen-voci__grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .zen-voci { padding: 60px 16px; }

  .zen-voci__card-overlay {
    opacity: 1;
    background: linear-gradient(to top, rgba(10, 10, 15, 0.85), transparent 60%);
  }
}

@media (prefers-reduced-motion: reduce) {
  .zen-voci__card {
    opacity: 1;
    transform: none;
    transition: none;
  }

  .zen-voci__card-img {
    transition: none;
  }
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  var cards = document.querySelectorAll('.zen-voci__card');
  if (!cards.length) return;

  if ('IntersectionObserver' in window) {
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          var idx = parseInt(entry.target.getAttribute('data-card-index')) || 0;
          setTimeout(function() {
            entry.target.classList.add('is-visible');
          }, idx * 80);
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });

    cards.forEach(function(card) { observer.observe(card); });
  } else {
    cards.forEach(function(card) { card.classList.add('is-visible'); });
  }
});
</script>

{% schema %}
{
  "name": "Zen Voci dal Cerchio",
  "class": "zen-voci-section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "La Nostra Comunità" },
    { "type": "text", "id": "heading", "label": "Titolo", "default": "Voci dal" },
    { "type": "text", "id": "heading_accent", "label": "Titolo accento (in oro)", "default": "Cerchio" },
    { "type": "url", "id": "instagram_url", "label": "Link Instagram" },
    { "type": "text", "id": "instagram_text", "label": "Testo CTA Instagram", "default": "Seguici su Instagram" }
  ],
  "blocks": [
    {
      "type": "ugc_card",
      "name": "Post",
      "limit": 8,
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Immagine" },
        { "type": "text", "id": "alt_text", "label": "Alt text", "default": "Comunità Benessere Zen" },
        { "type": "text", "id": "quote", "label": "Citazione cliente", "default": "" },
        { "type": "text", "id": "username", "label": "Nome utente", "default": "" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Zen Voci dal Cerchio",
      "blocks": [
        { "type": "ugc_card", "settings": { "quote": "L'ametista che ho ricevuto è stupenda", "username": "@elena_m" } },
        { "type": "ugc_card", "settings": { "quote": "La salvia bianca ha cambiato i miei rituali", "username": "@marco.zen" } },
        { "type": "ugc_card", "settings": { "quote": "Il tè dei 7 chakra è diventato il mio preferito", "username": "@giulia_yoga" } },
        { "type": "ugc_card", "settings": { "quote": "Spedizione velocissima e packaging curato", "username": "@laura_b" } }
      ]
    }
  ]
}
{% endschema %}
