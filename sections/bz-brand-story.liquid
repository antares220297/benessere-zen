{%- comment -%}
  BenesserEZen — Brand Story (two-column editorial).

  Left: eyebrow, blockquote in Cormorant italic, gold rule, body, CTA.
  Right: framed visual (image if uploaded, geometric sigil otherwise)
  with a "Est. … · …" tag in the bottom-right corner.
{%- endcomment -%}

{%- liquid
  assign reverse = section.settings.reverse_columns
-%}

<section
  class="bz-story color-{{ section.settings.color_scheme }} gradient isolate{% if reverse %} bz-story--reverse{% endif %}"
  data-section-id="{{ section.id }}"
>
  <div class="page-width bz-story__inner">
    <div class="bz-story__text">
      {%- if section.settings.eyebrow != blank -%}
        <p class="bz-label bz-reveal">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.quote != blank -%}
        <blockquote class="bz-story__quote bz-reveal" data-delay="1">
          {{ section.settings.quote | newline_to_br }}
        </blockquote>
      {%- endif -%}

      <hr class="bz-divider bz-reveal" data-delay="2">

      {%- if section.settings.body != blank -%}
        <div class="bz-body bz-story__body bz-reveal" data-delay="3">
          {{ section.settings.body }}
        </div>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        <a
          class="bz-btn-ghost bz-reveal"
          data-delay="4"
          href="{{ section.settings.cta_link | default: '/pages/about' }}"
        >
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="bz-story__visual bz-reveal" data-delay="2">
      <div class="bz-story__frame">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              class: 'bz-story__img',
              loading: 'lazy',
              widths: '400, 600, 800, 1000, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw'
          }}
        {%- else -%}
          <svg class="bz-story__sigil" viewBox="0 0 200 200" aria-hidden="true">
            <circle cx="100" cy="100" r="92" fill="none" stroke="var(--bz-gold)" stroke-width="0.5" opacity="0.6"/>
            <circle cx="100" cy="100" r="74" fill="none" stroke="var(--bz-gold)" stroke-width="0.5" stroke-dasharray="2 4" opacity="0.5"/>
            <circle cx="100" cy="100" r="56" fill="none" stroke="var(--bz-gold)" stroke-width="0.5" opacity="0.4"/>
            <path d="M 100 38 L 154 134 L 46 134 Z" fill="none" stroke="var(--bz-gold)" stroke-width="0.6" opacity="0.55"/>
            <path d="M 100 162 L 46 66 L 154 66 Z" fill="none" stroke="var(--bz-gold)" stroke-width="0.6" opacity="0.55"/>
            <circle cx="100" cy="100" r="3" fill="var(--bz-gold)" opacity="0.7"/>
          </svg>
        {%- endif -%}

        {%- if section.settings.tag != blank -%}
          <div class="bz-story__tag">{{ section.settings.tag }}</div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  .bz-story {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
  .bz-story__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 4rem;
    align-items: center;
  }
  .bz-story__text {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    align-items: flex-start;
  }
  .bz-story__text .bz-label,
  .bz-story__text .bz-divider,
  .bz-story__text .bz-btn-ghost { margin: 0; }

  .bz-story__quote {
    margin: 0;
    font-family: var(--bz-font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    line-height: 1.3;
    color: var(--bz-text);
    border: none;
    padding: 0;
  }
  .bz-story__quote em,
  .bz-story__quote i { color: var(--bz-gold); }

  .bz-story__body { margin: 0; }
  .bz-story__body p { margin: 0 0 1.4rem; }
  .bz-story__body p:last-child { margin-bottom: 0; }

  /* === Visual frame === */
  .bz-story__visual { width: 100%; }
  .bz-story__frame {
    position: relative;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--bz-border-gold);
    overflow: hidden;
    background:
      radial-gradient(ellipse at 50% 40%, rgba(201, 168, 76, 0.08), transparent 65%),
      var(--bz-bg-2);
  }
  .bz-story__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .bz-story__sigil {
    position: absolute;
    inset: 0;
    width: 65%;
    height: 65%;
    margin: auto;
    opacity: 0.55;
  }

  .bz-story__tag {
    position: absolute;
    bottom: 1.6rem;
    right: 1.6rem;
    padding: 0.8rem 1.4rem;
    border: 1px solid var(--bz-border-gold);
    background: rgba(15, 15, 15, 0.6);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    color: var(--bz-gold);
    font-family: var(--bz-font-ui);
    font-size: 0.9rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
  }

  /* === Desktop two-column === */
  @media (min-width: 990px) {
    .bz-story__inner {
      grid-template-columns: 1fr 1fr;
      gap: 5rem;
    }
    .bz-story--reverse .bz-story__inner > .bz-story__text { order: 2; }
    .bz-story--reverse .bz-story__inner > .bz-story__visual { order: 1; }
  }

  /* Mobile: visual goes second so eyebrow + quote lead the page */
  @media (max-width: 989px) {
    .bz-story__visual { order: 2; }
    .bz-story__text { order: 1; }
    .bz-story__frame { aspect-ratio: 4 / 5; }
  }
{% endstyle %}

{% schema %}
{
  "name": "BZ Brand Story",
  "class": "bz-brand-story-section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "default": "scheme-4",
      "label": "Schema colore"
    },
    {
      "type": "checkbox",
      "id": "reverse_columns",
      "label": "Inverti colonne (immagine a sinistra)",
      "default": false
    },
    {
      "type": "header",
      "content": "Testo"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Etichetta",
      "default": "La nostra storia"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Citazione",
      "default": "Non vendiamo prodotti.\nCuriamo rituali per chi cerca la propria verità."
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Testo",
      "default": "<p>BenesserEZen nasce da una trasformazione personale e dal desiderio di condividere il potere dei rituali quotidiani. Ogni cristallo, incenso e oggetto è scelto a mano, con cura, perché diventi parte del tuo percorso.</p>"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA",
      "default": "La nostra storia →"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Link CTA"
    },
    {
      "type": "header",
      "content": "Visual"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Foto brand (opzionale)",
      "info": "Senza immagine viene mostrato un sigillo geometrico in oro."
    },
    {
      "type": "text",
      "id": "tag",
      "label": "Tag (overlay basso a destra)",
      "default": "Est. 2023 · Cento, Italia"
    },
    {
      "type": "header",
      "content": "Spaziatura"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding alto",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding basso",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "BZ Brand Story"
    }
  ]
}
{% endschema %}
