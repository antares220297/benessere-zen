{%- comment -%}
  BenesserEZen — Hero Scroll-Driven (Dawn)

  Markup, CSS and JS are scoped to this section. Only external dep is
  the global :root token block in assets/custom.css.

  Structure
  ─────────
    #bz-hero-{section.id}        (250vh tall; creates the scroll lane)
      .bz-hero__media            (sticky, 100vh; image + smoke overlay)
      .bz-hero__texts            (fixed, full-vh; 3 sequential phrases)
      .bz-hero__cta              (fixed; appears at progress 0.75)
      .bz-hero__scroll-hint      (fixed; fades out after the first scroll)
{%- endcomment -%}

{%- liquid
  assign bg_image = section.settings.bg_image
  if bg_image != blank
    assign bg_url = bg_image | image_url: width: 2400
  endif
-%}

<section
  id="bz-hero-{{ section.id }}"
  class="bz-hero"
  data-section-id="{{ section.id }}"
>
  <div class="bz-hero__media" aria-hidden="true">
    <div
      class="bz-hero__media-inner"
      {% if bg_url %}style="background-image: url('{{ bg_url }}');"{% endif %}
    ></div>
    <div class="bz-hero__smoke"></div>
  </div>

  <div class="bz-hero__texts">
    <div class="bz-hero__text" data-at="0.10">{{ section.settings.text_1 | default: 'Respira.' }}</div>
    <div class="bz-hero__text" data-at="0.30">{{ section.settings.text_2 | default: 'Lascia andare.' }}</div>
    <div class="bz-hero__text bz-hero__text--gold" data-at="0.55">{{ section.settings.text_3 | default: 'Trova il tuo equilibrio.' }}</div>
  </div>

  <div class="bz-hero__cta">
    {%- if section.settings.cta_text_1 != blank -%}
      <a class="bz-btn" href="{{ section.settings.cta_link_1 | default: '/collections/all' }}">
        {{ section.settings.cta_text_1 }}
      </a>
    {%- endif -%}
    {%- if section.settings.cta_text_2 != blank -%}
      <a class="bz-btn-ghost" href="{{ section.settings.cta_link_2 | default: '/pages/quiz' }}">
        {{ section.settings.cta_text_2 }}
      </a>
    {%- endif -%}
  </div>

  <div class="bz-hero__scroll-hint" aria-hidden="true">
    <div class="bz-hero__scroll-line"></div>
    <span>Scorri</span>
  </div>
</section>

{% style %}
  #bz-hero-{{ section.id }} {
    position: relative;
    height: 250vh;
    background:
      radial-gradient(ellipse at 50% 40%, rgba(119, 68, 204, 0.10), transparent 55%),
      var(--bz-bg);
    color: var(--bz-text);
    overflow: clip;
  }

  #bz-hero-{{ section.id }} .bz-hero__media {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    z-index: 1;
  }

  #bz-hero-{{ section.id }} .bz-hero__media-inner {
    position: absolute;
    inset: 0;
    background-color: var(--bz-bg);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    filter: brightness(0.72);
    transform: scale(1);
    will-change: transform, filter, opacity;
    transition: transform 0.1s linear, filter 0.1s linear;
  }

  #bz-hero-{{ section.id }} .bz-hero__smoke {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(
      ellipse at center,
      transparent 0%,
      rgba(15, 15, 15, 0.30) 38%,
      rgba(15, 15, 15, 0.78) 70%,
      var(--bz-bg) 100%
    );
    opacity: 0;
    will-change: opacity;
    transition: opacity 0.1s linear;
  }

  #bz-hero-{{ section.id }} .bz-hero__texts {
    position: fixed;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.4rem;
    z-index: 2;
    pointer-events: none;
  }

  #bz-hero-{{ section.id }} .bz-hero__text {
    font-family: var(--bz-font-display);
    font-style: italic;
    font-weight: 300;
    font-size: clamp(3.2rem, 6vw, 7rem);
    line-height: 1.05;
    color: var(--bz-text);
    text-shadow: 0 2px 30px rgba(0, 0, 0, 0.55);
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.6s var(--bz-ease-out),
                transform 0.6s var(--bz-ease-out);
    will-change: opacity, transform;
  }

  #bz-hero-{{ section.id }} .bz-hero__text.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #bz-hero-{{ section.id }} .bz-hero__text.is-fading {
    opacity: 0;
    transform: translateY(-20px);
  }

  #bz-hero-{{ section.id }} .bz-hero__text--gold {
    font-size: clamp(3.6rem, 6.5vw, 7.6rem);
    color: var(--bz-gold);
    text-shadow: 0 0 40px rgba(201, 168, 76, 0.35),
                 0 2px 30px rgba(0, 0, 0, 0.55);
  }

  #bz-hero-{{ section.id }} .bz-hero__cta {
    position: fixed;
    left: 50%;
    bottom: 14vh;
    transform: translateX(-50%);
    display: flex;
    gap: 1.6rem;
    z-index: 3;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.6s var(--bz-ease-out);
    will-change: opacity;
  }

  #bz-hero-{{ section.id }} .bz-hero__cta.is-visible {
    opacity: 1;
    pointer-events: auto;
  }

  #bz-hero-{{ section.id }} .bz-hero__scroll-hint {
    position: fixed;
    left: 50%;
    bottom: 3rem;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.8rem;
    z-index: 4;
    pointer-events: none;
    color: var(--bz-muted);
    font-family: var(--bz-font-ui);
    font-size: 1rem;
    letter-spacing: 0.3rem;
    text-transform: uppercase;
    opacity: 1;
    transition: opacity 0.5s var(--bz-ease-out);
  }

  #bz-hero-{{ section.id }} .bz-hero__scroll-line {
    width: 1px;
    height: 3.2rem;
    background: linear-gradient(to bottom, transparent, var(--bz-gold));
    animation: bzHeroScrollLine 2.4s ease-in-out infinite;
    transform-origin: top;
  }

  @keyframes bzHeroScrollLine {
    0%, 100% { transform: scaleY(0.4); opacity: 0.4; }
    50%      { transform: scaleY(1);   opacity: 1; }
  }

  @media (max-width: 749px) {
    #bz-hero-{{ section.id }} { height: 220vh; }
    #bz-hero-{{ section.id }} .bz-hero__cta {
      flex-direction: column;
      gap: 1.2rem;
      bottom: 11vh;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    #bz-hero-{{ section.id }} .bz-hero__media-inner,
    #bz-hero-{{ section.id }} .bz-hero__smoke,
    #bz-hero-{{ section.id }} .bz-hero__text,
    #bz-hero-{{ section.id }} .bz-hero__cta,
    #bz-hero-{{ section.id }} .bz-hero__scroll-hint {
      transition: none !important;
    }
    #bz-hero-{{ section.id }} .bz-hero__scroll-line { animation: none; }
  }
{% endstyle %}

<script>
  (function () {
    var SECTION_ID = '{{ section.id }}';
    var hero = document.getElementById('bz-hero-' + SECTION_ID);
    if (!hero) return;

    var media       = hero.querySelector('.bz-hero__media-inner');
    var smoke       = hero.querySelector('.bz-hero__smoke');
    var texts       = hero.querySelectorAll('.bz-hero__text');
    var cta         = hero.querySelector('.bz-hero__cta');
    var scrollHint  = hero.querySelector('.bz-hero__scroll-hint');

    /* Reduced motion: surface every layer immediately, skip the controller. */
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      texts.forEach(function (t) { t.classList.add('is-visible'); });
      if (cta) cta.classList.add('is-visible');
      return;
    }

    var ticking = false;

    function update() {
      var rect = hero.getBoundingClientRect();
      var heroHeight = hero.offsetHeight;
      var winH = window.innerHeight;
      var scrolled = -rect.top;
      var range = heroHeight - winH;
      var progress = range > 0 ? Math.max(0, Math.min(1, scrolled / range)) : 0;

      /* Off-screen: hide content layers (sticky child stays in flow). */
      if (rect.bottom < 0 || rect.top > winH) {
        hero.style.visibility = 'hidden';
        ticking = false;
        return;
      }
      hero.style.visibility = 'visible';

      /* Media — scale 1→1.3, blur 0→20px, opacity 1→0 across [0.6, 1.0] */
      var p2 = Math.max(0, (progress - 0.6) / 0.4);
      var scale = 1 + progress * 0.3;
      var blur = p2 * 20;
      var mediaOpacity = 1 - p2;
      media.style.transform = 'scale(' + scale + ')';
      media.style.filter = 'brightness(' + (0.72 - progress * 0.32) + ') blur(' + blur + 'px)';
      media.style.opacity = mediaOpacity;

      /* Smoke — opacity 0→1 across [0, 0.5] */
      smoke.style.opacity = Math.max(0, Math.min(1, progress / 0.5));

      /* Texts — visible from data-at to data-at + 0.22 */
      for (var i = 0; i < texts.length; i++) {
        var el = texts[i];
        var threshold = parseFloat(el.getAttribute('data-at')) || 0;
        var fadeOutAt = threshold + 0.22;
        if (progress >= threshold && progress < fadeOutAt) {
          el.classList.add('is-visible');
          el.classList.remove('is-fading');
        } else if (progress >= fadeOutAt) {
          el.classList.remove('is-visible');
          el.classList.add('is-fading');
        } else {
          el.classList.remove('is-visible');
          el.classList.remove('is-fading');
        }
      }

      /* CTA at 0.75 */
      if (cta) cta.classList.toggle('is-visible', progress >= 0.75);

      /* Scroll hint fades out across the first 5% */
      if (scrollHint) {
        scrollHint.style.opacity = progress < 0.05
          ? 1
          : Math.max(0, 1 - (progress - 0.05) * 12);
      }

      ticking = false;
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(update);
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
    update();
  })();
</script>

{% schema %}
{
  "name": "BZ Hero Scroll",
  "class": "bz-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Sfondo"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Immagine/GIF di sfondo",
      "info": "Per una GIF animata caricala in Content > Files e selezionala qui."
    },
    {
      "type": "header",
      "content": "Testi (in sequenza durante lo scroll)"
    },
    {
      "type": "text",
      "id": "text_1",
      "label": "Testo 1",
      "default": "Respira."
    },
    {
      "type": "text",
      "id": "text_2",
      "label": "Testo 2",
      "default": "Lascia andare."
    },
    {
      "type": "text",
      "id": "text_3",
      "label": "Testo 3 (oro)",
      "default": "Trova il tuo equilibrio."
    },
    {
      "type": "header",
      "content": "Call to Action"
    },
    {
      "type": "text",
      "id": "cta_text_1",
      "label": "CTA primario",
      "default": "Scopri la collezione"
    },
    {
      "type": "url",
      "id": "cta_link_1",
      "label": "Link CTA primario"
    },
    {
      "type": "text",
      "id": "cta_text_2",
      "label": "CTA secondario",
      "default": "Fai il quiz →"
    },
    {
      "type": "url",
      "id": "cta_link_2",
      "label": "Link CTA secondario"
    }
  ],
  "presets": [
    {
      "name": "BZ Hero Scroll"
    }
  ]
}
{% endschema %}
